{
  "name": "cfw-open-graph-image-generation-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-03-01",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "api-portfolio-db",
      "database_id": "PASTE_YOUR_D1_DATABASE_ID_HERE"
    }
  ], "r2_buckets": [ { "binding": "R2", "bucket_name": "og-image-assets" } ]
}
